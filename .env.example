# Copy this file to .env and set exactly one provider key.
#
# The local chatbot uses this key to translate natural-language questions into
# typed AnalysisPlan JSON. The dataframe itself stays local.

# Choose one: openai, anthropic, gemini.
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional global override. If set, this takes precedence over provider-specific models.
# LLM_MODEL=

# Optional request timeout in seconds.
LLM_TIMEOUT_SECONDS=60
